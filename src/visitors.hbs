<html>

<head>
  <meta charset="utf-8" />
  <title>Visitors</title>
  <style>
    table {
      width: 100%;
      border-collapse: collapse;
    }

    table,
    th,
    td {
      border: 1px solid black;
    }

    th,
    td {
      padding: 8px;
      text-align: left;
      vertical-align: top;
    }

    th {
      background-color: #f2f2f2;
    }

    tr:nth-child(even) {
      background-color: #f9f9f9;
    }

    .badge {
      display: inline-block;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 12px;
      font-weight: bold;
    }

    .badge-browser {
      background: #d4edda;
      color: #155724;
    }

    .badge-request {
      background: #fff3cd;
      color: #856404;
    }

    .badge-probe {
      background: #f8d7da;
      color: #721c24;
    }

    .badge-blocked {
      background: #343a40;
      color: #fff;
    }

    .visit-url {
      word-break: break-all;
      font-family: monospace;
      font-size: 12px;
    }

    .visit-meta {
      color: #555;
      font-size: 12px;
    }
  </style>
</head>

<body>
  <table>
    <tr>
      <th>id</th>
      <th>ip</th>
      <th>visits</th>
      <th>country</th>
      <th>city</th>
      <th>longitude</th>
      <th>latitude</th>
      <th>first seen</th>
    </tr>
    {{#each visitors}}
    <tr>
      <td>{{id}}</td>
      <td>{{ip}}</td>
      <td>
        <details>
          <summary>{{count}} visit(s)</summary>
          <ul>
            {{#each visits}}
            <li>
              <span class="badge badge-{{badge}}">{{badge}}</span>
              <span class="visit-meta">{{kind}}{{#if visitedAt}} · {{visitedAt}}{{/if}}</span>
              <div class="visit-url">{{targetUrl}}</div>
              {{#if documentTitle}}
              <div class="visit-meta">title: {{documentTitle}}</div>
              {{/if}}
              {{#if hasReport}}
              <div class="visit-meta">
                monetised: {{imagesReplaced}} image(s){{#if pageLoadMs}}, load {{pageLoadMs}}ms{{/if}}
              </div>
              {{/if}}
              {{#if blockReason}}
              <div class="visit-meta">blocked: {{blockReason}}</div>
              {{/if}}
            </li>
            {{/each}}
          </ul>
        </details>
      </td>
      <td>{{country}}</td>
      <td>{{city}}</td>
      <td>{{longitude}}</td>
      <td>{{latitude}}</td>
      <td>{{date}}</td>
    </tr>
    {{/each}}
  </table>
</body>

</html>
