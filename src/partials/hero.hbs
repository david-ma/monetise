<section class="hero">
  <div class="hero__layout">
    <div class="hero__copy">
      <p class="eyebrow">Claude Monet × your browser</p>
      <h1>Monetise your website</h1>
      <p class="lede">Instantly monetise any website with our quick and easy service.</p>

      <form method="get" class="monetise-form" id="monetise-form">
        <label class="monetise-form__label" for="goto">URL</label>
        <div class="monetise-form__row">
          <input
            type="url"
            id="goto"
            name="goto"
            autofocus
            placeholder="https://website.com"
            required
          />
          <button type="submit">Get started</button>
        </div>
      </form>

      <p class="hero__hint">
        This service will automatically monetise any website. Enter a URL above and hit go.
      </p>
    </div>

    <div class="hero__art">
      <img src="/images/unsplash.jpg" alt="Claude Monet, impressionist landscape" width="640" height="480" />
    </div>
  </div>
</section>
